# ================================================================== #
# Lead Generation System — Environment Variables                     #
# Copy this file to .env and fill in real values.                    #
# NEVER commit .env with real keys to version control.               #
# ================================================================== #

# ------------------------------------------------------------------ #
# PHASE 1 — Required for full functionality                           #
# ------------------------------------------------------------------ #

# Google Places API key — used to find plumbers in London
# Get one at: https://console.cloud.google.com/
# Enable: "Places API" on the project
# Note: Text Search + Place Details calls will accrue charges
GOOGLE_API_KEY=

# ------------------------------------------------------------------ #
# PHASE 1 — Optional (system works without these)                    #
# ------------------------------------------------------------------ #

# UK Food Standards Agency API — no key needed (public open data)
# Leave blank; the system will call the FSA API without authentication
FOOD_DATA_API_KEY=

# Database — SQLite path for Phase 1
# Phase 2: change to postgresql+psycopg2://user:pass@host/dbname
DATABASE_URL=sqlite:///./leadgen.db

# Frontend API base URL (used by Next.js to reach the backend)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ------------------------------------------------------------------ #
# PHASE 2 — Uncomment and fill in when upgrading                     #
# ------------------------------------------------------------------ #

# Companies House API — find newly formed hospitality/property companies
# Register at: https://developer.company-information.service.gov.uk/
# COMPANIES_HOUSE_API_KEY=

# UK Planning / LDRS data API
# PLANNING_DATA_API_KEY=

# Redis + Celery (Phase 2 background jobs)
# REDIS_URL=redis://localhost:6379/0

# ElevenLabs — optional voice generation for outreach audio
# ELEVENLABS_API_KEY=
